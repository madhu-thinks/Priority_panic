# Priority Panic Environment Configuration
# Copy this file to .env and fill in your values
# Never commit .env to version control (add to .gitignore)

# ==================== REQUIRED ====================

# HuggingFace API Token
# Get this from: https://huggingface.co/settings/tokens
# Create a NEW token with "read" permission
HF_TOKEN=hf_YOUR_TOKEN_HERE

# LLM API Endpoint
# Use HuggingFace Router (free, default):
API_BASE_URL=https://router.huggingface.co/v1

# Or use OpenAI (paid):
# API_BASE_URL=https://api.openai.com/v1

# LLM Model to use
# HuggingFace Router models:
#   - Qwen/Qwen2.5-72B-Instruct (default, fast)
#   - meta-llama/Llama-2-70b-chat-hf
#   - mistralai/Mistral-7B-Instruct-v0.2
#
# OpenAI models:
#   - gpt-4
#   - gpt-3.5-turbo
MODEL_NAME=Qwen/Qwen2.5-72B-Instruct

# ==================== OPTIONAL ====================

# For local Docker testing
# Set this to test with a locally built Docker image
# Example: priority_panic-env:latest
# LOCAL_IMAGE_NAME=priority_panic-env:latest

# For deployed HuggingFace Space
# Set this to test against your deployed environment
# Example: https://your-username-priority-panic.hf.space
# HF_SPACE_URL=https://your-username-priority-panic.hf.space

# ==================== TEMPORARY (FOR TESTING) ====================

# Alternatively, use API_KEY instead of HF_TOKEN (legacy)
# API_KEY=your_api_key_here
