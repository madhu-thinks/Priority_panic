# ========================================================
# Priority Panic Environment Configuration
# Copy this file to .env and fill in your values.
# NEVER COMMIT .env TO VERSION CONTROL.
# ========================================================

# -------------------- REQUIRED --------------------

# HuggingFace API Token (Ensure it has "Read" permissions)
# Get it from: https://huggingface.co/settings/tokens
HF_TOKEN=hf_your_token_here

# LLM API Endpoint
# Default: HuggingFace Router (Free/Pro)
API_BASE_URL=https://router.huggingface.co/v1

# Alternative: SambaNova (Fastest for Llama 3.1)
# API_BASE_URL=https://api.sambanova.ai/v1

# LLM Model Name
# Recommended for RL Logic & JSON:
# - meta-llama/Llama-3.1-70B-Instruct (Best for Reasoning)
# - Qwen/Qwen2.5-72B-Instruct (Fast & Reliable)
MODEL_NAME=meta-llama/Llama-3.1-70B-Instruct

# -------------------- ENVIRONMENT --------------------

# Deployment URL (Required for client.py to connect)
# Example: https://username-priority-panic.hf.space
HF_SPACE_URL=https://your-username-priority-panic.hf.space

# Optimization Settings
MAX_STEPS=9
TEMPERATURE=0.0

# -------------------- OPTIONAL --------------------

# For local Docker testing
# LOCAL_IMAGE_NAME=priority_panic-env:latest

# Legacy support for older scripts
# API_KEY=your_api_key_here

# ========================================================
# PRO-TIP: For the Hackathon, use Llama-3.1-70B if available, 
# as it handles the "reasoning" field in our models.py 
# significantly better than smaller models.
# ========================================================